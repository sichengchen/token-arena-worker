{
  "name": "token-arena",
  "version": "0.3.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev:api": "pnpm --filter ./api dev",
    "dev:web": "pnpm --filter ./web dev",
    "build:api": "pnpm --filter ./api build",
    "build:web": "pnpm --filter ./web build",
    "build": "pnpm run build:api && pnpm run build:web",
    "check": "pnpm --filter ./api check && pnpm --filter ./web check",
    "check:api": "pnpm --filter ./api check",
    "check:web": "pnpm --filter ./web check",
    "prepare": "husky",
    "deploy:api": "pnpm --filter ./api deploy",
    "deploy:web": "pnpm --filter ./web deploy"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
