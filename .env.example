# Better Auth
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:3000

# Auth Mode (self-hosted | production)
# - self-hosted: Email/password authentication only (for self-deployed instances)
# - production: OAuth-only authentication (Discord/GitHub/Google/Linux.do/Watcha, for cloud-hosted service)
AUTH_MODE=self-hosted

# OAuth Providers (required only when AUTH_MODE=production)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINUXDO_CLIENT_ID=
LINUXDO_CLIENT_SECRET=
WATCHA_CLIENT_ID=
WATCHA_CLIENT_SECRET=

# Discord OAuth2 setup
# Redirect URI (local): http://localhost:3000/api/auth/callback/discord
# Recommended scopes: identify email

# Google Analytics (optional; omit to disable)
# GA_SECRET=G-XXXXXXXXXX

# Microsoft Clarity (optional; omit to disable)
# CLARITY_ID=your-project-id

# Wechat Share
NEXT_PUBLIC_APP_ORIGIN=https://your-domain.com
WECHAT_OPEN_APP_ID=wx1234567890abcdef
WECHAT_OPEN_APP_SECRET=xxxxxxxxxxxxxxxx
